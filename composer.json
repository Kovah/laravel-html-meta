{
    "name": "kovah/laravel-html-meta",
    "description": "A Laravel package to parse meta information from an URL.",
    "keywords": [
        "html",
        "meta",
        "parser",
        "laravel"
    ],
    "homepage": "https://github.com/kovah/laravel-html-meta",
    "license": "MIT",
    "authors": [
        {
            "name": "Kevin Woblick",
            "email": "mail@woblick.dev",
            "homepage": "https://woblick.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-iconv": "*",
        "guzzlehttp/guzzle": "^7.2",
        "illuminate/http": "^11.0 | ^12.0 | ^13.0",
        "illuminate/support": "^11.0 | ^12.0 | ^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.4.2",
        "orchestra/testbench": "^9.0 | ^10.0 | ^11.0",
        "phpunit/phpunit": "^9.0 | ^10.0 | ^11.0 | ^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "Kovah\\HtmlMeta\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kovah\\HtmlMeta\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kovah\\HtmlMeta\\HtmlMetaServiceProvider"
            ],
            "aliases": {
                "HtmlMeta": "Kovah\\HtmlMeta\\Facades\\HtmlMeta"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/kovah"
        }
    ]
}
